# Шаблон ENV — скопируйте в apps/web/.env.local и заполните реальными значениями.
# Реальные секреты НИКОГДА не коммитим (проверка: apps/web/.gitignore → .env*).
# Полный справочник с источниками — docs/env-vars.md.

# ─── Supabase (server) ─────────────────────────────────────
DATABASE_URL=postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:6543/postgres
DATABASE_URL_DIRECT=postgresql://postgres.xxx:password@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=                   # SERVER ONLY — обходит RLS

# ─── Supabase (client, браузерный клиент через @supabase/ssr) ──
# Next.js инлайнит только NEXT_PUBLIC_*. Используется lib/supabase/browser.ts.
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Telegram ──────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=                     # случайная строка, сверяется с X-Telegram-Bot-Api-Secret-Token
TELEGRAM_OPERATORS_GROUP_ID=                 # -100... ID группы операторов с forum-topics

# ─── AI ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-6

# ─── Payments (Sprint 2) ───────────────────────────────────
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=
CRYPTOBOT_TOKEN=
CRYPTOBOT_WEBHOOK_SECRET=

# ─── Rate limit (Sprint 3, Upstash Ratelimit на /api/chat) ──
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ─── Background jobs (Sprint 3, Trigger.dev) ───────────────
TRIGGER_API_KEY=
TRIGGER_API_URL=https://api.trigger.dev

# ─── Observability ─────────────────────────────────────────
SENTRY_DSN=
SENTRY_AUTH_TOKEN=                           # нужен только для source-map upload в CI build
NEXT_PUBLIC_SENTRY_DSN=                      # тот же DSN, но публичный — для client-side Sentry init
LOG_LEVEL=debug                              # fatal|error|warn|info|debug|trace; default: debug в dev, info в prod

# ─── App ───────────────────────────────────────────────────
APP_URL=https://oplati.example.com           # для формирования webhook URL и ссылок оплаты
NEXT_PUBLIC_APP_URL=https://oplati.example.com
NODE_ENV=development
